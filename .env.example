# Socket Mode connection (App-Level Token, connections:write)
SLACK_APP_TOKEN=xapp-...
# Bot token (xoxb-) — needed for the socket connection / auth test / control channel
SLACK_BOT_TOKEN=xoxb-...
# User token (xoxp-) — act as yourself (post / react under your own name)
SLACK_USER_TOKEN=xoxp-...
# SQLite path (optional; default: $XDG_CONFIG_HOME/slack-deputy/slack-deputy.db,
# falling back to ~/.config/slack-deputy/slack-deputy.db)
# SLACK_DEPUTY_DB=
# Channels to capture even without a mention (optional, comma-separated channel IDs)
# SLACK_DEPUTY_WATCH_CHANNELS=C0123456789,C0234567890
# DM/group-DM channels that dispatch only when mentioned — a blacklist for noisy
# DMs (optional, comma-separated channel IDs). DMs are directed by default.
# SLACK_DEPUTY_DM_MENTION_ONLY=D0123456789,D0234567890
# HTTP API bind address (optional, default 127.0.0.1:8799). Use 0.0.0.0:8799 to
# serve a consumer on another host — only over a trusted tailnet (no auth).
# SLACK_DEPUTY_LISTEN=127.0.0.1:8799
